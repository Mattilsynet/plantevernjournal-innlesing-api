### Delete plantevernjournal for frø og formeringsmateriale
DELETE http://localhost:8080/plantevernjournal/innlesing/v1/formeringsmateriale/{{formeringsmaterialeId}}
Content-Type: application/json

> {%
    client.test("Sletting av frø og formeringsmateriale gikk bra", function () {
        client.assert(response.status === 204, "Status er ikke 204");
    });

%}

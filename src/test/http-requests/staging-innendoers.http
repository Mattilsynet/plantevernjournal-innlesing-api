### Post plantevernjournal for innendørs bruk
POST https://plantevernjournal-innlesing-api.plantevernjournal-staging.mattilsynet.io/plantevernjournal/innlesing/v1/innendoersbruk
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "behandledeVekster":  [
    {
      "bbchFase": "05",
      "eppoKode": "ORSAN",
      "partinummer": 2,
      "sort": "Orchis anatolica"
    },
    {
      "bbchFase": "01",
      "eppoKode": "KRCSS",
      "partinummer": 27,
      "sort": "Chrysactinium sp."
    }
  ],
  "behandler": {
    "etternavn": "Olsen",
    "fornavn": "Lars"
  },
  "behandletDato": "2024-10-18",
  "behandledeOmraader": {
    "type": "FeatureCollection",
    "features": [
      {
        "type": "Feature",
        "geometry": {
          "type": "Point",
          "coordinates": [
            10.742875,
            59.921951
          ]
        }
      }
    ]
  },
  "bruksomraade": "JORDBRUK",
  "bygningsnummer": "512",
  "bygningsstoerrelse": {
    "enhet": "KVADRATMETER",
    "verdi": 450
  },
  "organisasjonsnummerEier": "987654123",
  "organisasjonsnummerSproeyter": "897456875",
  "plantevernmiddel": [
    {
      "dosering": {
        "enhet": "LITER_PER_KILO",
        "verdi": 34
      },
      "registreringsnummer": "12345"
    }
  ]
}

> {%
    client.test("Innlesing av innendørs bruk gikk bra", function () {
        client.assert(response.status === 201, "Status er ikke 201");
    });

    const id = jsonPath(response.body, '$.id')
    client.global.set("innendoersId", id)
%}

### Delete plantevernjournal for innendørs bruk
DELETE https://plantevernjournal-innlesing-api.plantevernjournal-staging.mattilsynet.io/plantevernjournal/innlesing/v1/innendoersbruk/{{innendoersId}}
Authorization: Bearer {{token}}
Content-Type: application/json

> {%
    client.test("Sletting av innendørs bruk gikk bra", function () {
        client.assert(response.status === 204, "Status er ikke 204");
    });

%}

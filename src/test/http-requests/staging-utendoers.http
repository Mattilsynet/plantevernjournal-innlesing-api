### Delete plantevernjournal for utendørs bruk
DELETE https://plantevernjournal-innlesing-api.plantevernjournal-staging.mattilsynet.io/plantevernjournal/innlesing/v1/utendoersbruk/{{utendoersId}}
Authorization: Bearer {{token}}
Content-Type: application/json

> {%
    client.test("Sletting av utendørsbruk gikk bra", function () {
        client.assert(response.status === 204, "Status er ikke 204");
    });

%}
